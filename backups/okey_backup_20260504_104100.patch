-  int _slotIndexForAbsoluteSeat(int absoluteSeat) {
-    final my = _mySeatIndexAbs ?? 0;
-    final relative = (absoluteSeat - my + _maxPlayers) % _maxPlayers;
-    if (_maxPlayers == 2) {
-      return relative == 0 ? 3 : 0;
-    }
-    switch (relative) {
-      case 0:
-        return 3; // me -> bottom-right
-      case 1:
-        return 2; // left
-      case 2:
-        return 0; // top
-      case 3:
-        return 1; // right
-      default:
-        return 3;
-    }
-  }
