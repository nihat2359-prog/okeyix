-    return {
-      'id': (raw['id'] ?? '').toString(),
-      'value': value,
-      'color': (raw['color'] ?? '').toString(),
-      'isJoker':
-          raw['isJoker'] == true ||
-          raw['joker'] == true ||
-          raw['is_joker'] == true,
-      'isFakeJoker':
-          raw['isFakeJoker'] == true ||
-          raw['fake_joker'] == true ||
