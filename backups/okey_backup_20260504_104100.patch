-        }
-      }
-      if (_maxPlayers == 2) {
-        final oppSeat = ((_resolveMySeatIndex() ?? 0) + 1) % 2;
-        final slot = _discardSlotsByIndex[_slotIndexForAbsoluteSeat(oppSeat)];
